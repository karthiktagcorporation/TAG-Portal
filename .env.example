# Copy this file to .env and fill in your values, then restart the server.

# Security — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# API port (frontend dev server proxies /api to this)
API_PORT=4100

# Public URL of the portal, used in email links
PORTAL_URL=http://localhost:5173

# SMTP settings for mail notifications (welcome emails, new-app alerts).
# Leave blank to disable email — the portal works fine without it.
# Example for Office 365:  smtp.office365.com / 587
# Example for Gmail:       smtp.gmail.com / 587 (use an App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TAG Portal <tagis@tagcorporation.net>"
